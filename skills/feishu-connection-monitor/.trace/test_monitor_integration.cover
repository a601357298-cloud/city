    1:         old = time.time() - 61
    1:         Path(self.signal_file).write_text("stale", encoding="utf-8")
    1:         os.utime(self.signal_file, (old, old))
    4:         content = f"""
       monitor:
         heartbeat_seconds: 30
         timeout_seconds: 30
         failure_threshold: 1
         idempotent_window_seconds: 300
