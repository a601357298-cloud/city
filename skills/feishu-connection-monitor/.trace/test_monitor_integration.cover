    1:     def tearDown(self):
    1:         self.temp_dir.cleanup()
       
    1:     def test_simulate_60s_disconnect_then_auto_recover(self):
    1:         config_manager = ConfigManager(self.config_path)
    1:         cfg = config_manager.load_if_changed()
    1:         http_client = IntegrationHttpClient()
    2:         monitor = ConnectionMonitor(config_manager, JsonlLogger(cfg.log_dir), http_client, sleeper=lambda _: None)
    1:         first = monitor.run_once(cfg)
    1:         self.assertEqual(first["status"], "up")
    1:         self.assertIn("refresh_token", first["recovery_action"])
    1:         self.assertEqual(http_client.recovery_count, 1)
    1:         files = list(Path(self.log_dir).glob("feishu-monitor-*.log"))
    1:         self.assertTrue(files)
    1:         payload = files[0].read_text(encoding="utf-8")
    1:         self.assertIn("recovery_action", payload)
       
       
