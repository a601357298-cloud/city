    1:     def test_yaml_scalar_parse(self):
    2:         data = """
       root:
         text1: "abc"
         text2: 'def'
         bool1: true
         bool2: false
         null1: null
         number1: 12
         number2: 1.5
    1: """.strip()
    1:         parsed = SimpleYamlParser.parse(data)
    1:         self.assertEqual(parsed["root"]["text1"], "abc")
    1:         self.assertEqual(parsed["root"]["text2"], "def")
    1:         self.assertEqual(parsed["root"]["bool1"], True)
    1:         self.assertEqual(parsed["root"]["bool2"], False)
    1:         self.assertEqual(parsed["root"]["null1"], None)
    1:         self.assertEqual(parsed["root"]["number1"], 12)
    1:         self.assertEqual(parsed["root"]["number2"], 1.5)
       
