    1:     def _start_server(self, routes, post_routes):
    1:         StatefulHandler.routes = routes
    1:         StatefulHandler.post_routes = post_routes
    1:         server = HTTPServer(("127.0.0.1", 19080), StatefulHandler)
    1:         thread = threading.Thread(target=server.serve_forever, daemon=True)
    1:         thread.start()
    1:         return server
       
    1:     def test_send_probe_200_branch(self):
