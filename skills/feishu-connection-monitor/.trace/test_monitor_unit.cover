    1:         try:
    1:             Path(self.signal_file).write_text("ok", encoding="utf-8")
    1:             monitor = ConnectionMonitor(DummyConfigManager(self.base_cfg), JsonlLogger(self.log_dir), HttpClient(), sleeper=lambda _: None)
    1:             result = monitor.run_once(self.base_cfg)
